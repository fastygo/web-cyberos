# Copy to .env: cp .env.example .env
# Generate: openssl rand -base64 32

# HMAC key for website session cookies (must stay secret)
SITE_SESSION_KEY=change-me-to-a-long-random-secret

# SAML / URLs (must match your DNS and TLS termination)
SP_ENTITY_ID=https://cybeross.ru
SP_ACS_URL=https://cybeross.ru/saml/acs
IDP_SSO_URL=https://idp.cybeross.ru/sso

# Before first run: mkdir -p certs && copy IdP public cert to certs/idp.crt
